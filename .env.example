# ─────────────────────────────────────────────────────────────────────────────
# Brevo email engine — config for the Cloudflare Pages Functions (functions/api/*).
# These are SERVER-SIDE env vars, NOT bundled into the client (no VITE_ prefix).
#
# Production: set them in Cloudflare → Pages → pum-snacks → Settings → Variables and
#   Secrets. Mark BREVO_API_KEY as a "Secret" (encrypted). Redeploy to apply.
# Local:      copy the values you want into a `.dev.vars` file (gitignored) and run
#   `npx wrangler pages dev dist` to exercise the Functions locally.
#
# If BREVO_API_KEY / list / template are unset, the Functions simulate success so the
# forms keep working pre-launch (nothing is sent to Brevo).
# ─────────────────────────────────────────────────────────────────────────────

# Required — Brevo API v3 key (Brevo → SMTP & API → API Keys). Keep secret.
BREVO_API_KEY=

# Required — numeric ID of the Brevo list that all signups land in
# (Brevo → Contacts → Lists → open the list → ID in the URL/settings).
BREVO_LIST_ID=

# Required for subscribe — numeric ID of the double opt-in email template
# (Brevo → Campaigns/Templates → your DOI template). The template must reference
# the confirmation link via {{ doubleOptInUrl }} and may use {{ params.DOIurl }}.
BREVO_DOI_TEMPLATE_ID=

# Where Brevo sends the user AFTER they click the confirmation link in the DOI email.
# Defaults to https://pum.mx/confirmacion if unset.
BREVO_DOI_REDIRECT_URL=https://pum.mx/confirmacion

# Contact form (/api/contact) — owner notification email.
# Where contact-form messages are delivered. Defaults to hola@pum.mx.
CONTACT_NOTIFY_EMAIL=hola@pum.mx
# Verified Brevo sender for the notification email. Defaults to hola@pum.mx / ¡PUM!.
BREVO_SENDER_EMAIL=hola@pum.mx
BREVO_SENDER_NAME=¡PUM!
